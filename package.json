{
  "name": "tiktok-chats-visualizer",
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bunx eslint . --ext .js,.ts",
    "lint:fix": "bunx eslint . --ext .js,.ts --fix",
    "format": "bunx prettier --write .",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:client": "bunx tsc -p tsconfig.client.json --noEmit"
  },
  "keywords": [],
  "author": "kotru21",
  "license": "ISC",
  "description": "Анализатор и визуализатор чатов TikTok (без сервера)",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.4",
    "@types/bun": "^1.3.11",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2"
  }
}
