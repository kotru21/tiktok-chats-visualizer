{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": [],
    "rootDir": ".",
    "outDir": "./dist/client",
    "paths": {
      "@/*": ["./public/js/*"],
      "@types/*": ["./types/*"]
    },
    "composite": true,
    "declarationDir": "./dist/client/types",
    "allowJs": true,
    "checkJs": false
  },
  "include": ["public/js/**/*.ts", "types/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
